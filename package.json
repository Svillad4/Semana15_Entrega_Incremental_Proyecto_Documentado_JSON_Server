{
  "name": "semana15-entrega-incremental-proyecto-documentado",
  "version": "1.0.0",
  "description": "Proyecto educativo Semana 15: entrega incremental, documentacion tecnica, bitacora, validacion y exposicion con Vite y JSON Server.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "db": "json-server --watch db.json --port 3001",
    "start": "concurrently \"npm run db\" \"npm run dev\"",
    "check": "node scripts/check-project.js",
    "reset-db": "node scripts/reset-db.js",
    "evidencias": "node scripts/create-evidence-folders.js"
  },
  "dependencies": {
    "@vitejs/plugin-basic-ssl": "latest",
    "bootstrap": "^5.3.3",
    "bootstrap-icons": "^1.11.3",
    "chart.js": "^4.4.4",
    "sweetalert2": "^11.14.0"
  },
  "devDependencies": {
    "@vitejs/plugin-basic-ssl": "latest",
    "concurrently": "^8.2.2",
    "json-server": "^0.17.4",
    "vite": "^5.4.0"
  }
}